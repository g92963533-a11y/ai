# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Authentication
BETTER_AUTH_SECRET=your_secret_key_here_min_32_chars_recommended

# Google OAuth - Get from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Public Google Client ID (used in frontend - safe to expose)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# Environment
NODE_ENV=development

# Deployment URLs (auto-set by Vercel)
VERCEL_URL=your_deployment_url.vercel.app
VERCEL_PROJECT_PRODUCTION_URL=your_production_url.vercel.app
